generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  birthDate     DateTime?
  country       String?
  bio           String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tripMemberships TripMember[]
  tripInvitations TripInvitation[]
  sentTripInvitations TripInvitation[] @relation("TripInvitationSender")
  notifications Notification[]
  tripChatMessages TripChatMessage[]
}

model Trip {
  id          String       @id @default(cuid())
  title       String
  description String?
  destination String
  destinationPlaceId String?
  destinationLat Float?
  destinationLng Float?
  category    String       @default("Sonstiges")
  timeMode    TripTimeMode @default(FIXED)
  startDate   DateTime
  endDate     DateTime
  planningStartDate DateTime?
  planningEndDate DateTime?
  plannedDurationDays Int?
  participantMode TripParticipantMode @default(NONE)
  participantFixedCount Int?
  participantMinCount Int?
  participantMaxCount Int?
  coverImage  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     TripMember[]
  invitations TripInvitation[]
  notifications Notification[]
  chatMessages TripChatMessage[]
  itineraryDays TripItineraryDay[]
  budgetItems TripBudgetItem[]
}

model TripMember {
  tripId    String
  userId    String
  role      TripRole      @default(MEMBER)
  createdAt DateTime      @default(now())
  trip      Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([tripId, userId])
  @@index([userId])
}

enum TripRole {
  OWNER
  ADMIN
  MEMBER
}

model TripInvitation {
  id              String               @id @default(cuid())
  tripId           String
  userId           String
  invitedByUserId  String
  status           TripInvitationStatus @default(PENDING)
  expiresAt        DateTime
  respondedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  trip             Trip                 @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy        User                 @relation("TripInvitationSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([tripId, userId])
  @@index([userId, status])
  @@index([tripId, status])
}

enum TripInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model Notification {
  id           String           @id @default(cuid())
  userId       String
  tripId       String?
  invitationId String?
  type         NotificationType
  title        String
  message      String
  link         String?
  isRead       Boolean          @default(false)
  readAt       DateTime?
  createdAt    DateTime         @default(now())
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip         Trip?            @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([tripId, createdAt])
  @@index([invitationId])
}

enum NotificationType {
  INVITATION_RECEIVED
  INVITATION_ACCEPTED
  INVITATION_DECLINED
  TRIP_UPDATED
  ITINERARY_UPDATED
  BUDGET_UPDATED
  PARTICIPANTS_UPDATED
  ROLE_UPDATED
}

model TripChatMessage {
  id        String              @id @default(cuid())
  tripId    String
  userId    String?
  type      TripChatMessageType @default(USER)
  content   String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  trip      Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tripId, createdAt])
  @@index([userId, createdAt])
}

enum TripChatMessageType {
  USER
  SYSTEM
}

model TripItineraryDay {
  id        String    @id @default(cuid())
  tripId    String
  dayNumber Int
  summary   String
  location  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tags      TripItineraryTag[]
  activities TripItineraryActivity[]

  @@unique([tripId, dayNumber])
  @@index([tripId, dayNumber])
}

model TripItineraryTag {
  id     String           @id @default(cuid())
  dayId  String
  label  String
  day    TripItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model TripItineraryActivity {
  id        String           @id @default(cuid())
  dayId     String
  time      String
  title     String
  type      ActivityType     @default(ACTIVITY)
  createdAt DateTime         @default(now())
  day       TripItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId, createdAt])
}

model TripBudgetItem {
  id                 String   @id @default(cuid())
  tripId             String
  title              String
  category           String
  pricingMode        BudgetPricingMode @default(GROUP_TOTAL)
  peopleCount        Int      @default(1)
  estimatedCostCents Int
  dayStart           Int?
  dayEnd             Int?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  trip               Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, createdAt])
}

enum BudgetPricingMode {
  PER_PERSON
  GROUP_TOTAL
}

enum ActivityType {
  FLIGHT
  LODGING
  FOOD
  ACTIVITY
}

enum TripTimeMode {
  FIXED
  FLEXIBLE
}

enum TripParticipantMode {
  NONE
  FIXED
  RANGE
}
