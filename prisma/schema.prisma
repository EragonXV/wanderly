generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tripMemberships TripMember[]
}

model Trip {
  id          String       @id @default(cuid())
  title       String
  description String?
  destination String
  destinationPlaceId String?
  destinationLat Float?
  destinationLng Float?
  category    String       @default("Sonstiges")
  startDate   DateTime
  endDate     DateTime
  coverImage  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     TripMember[]
  itineraryDays TripItineraryDay[]
  budgetItems TripBudgetItem[]
}

model TripMember {
  tripId    String
  userId    String
  role      TripRole      @default(MEMBER)
  createdAt DateTime      @default(now())
  trip      Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([tripId, userId])
  @@index([userId])
}

enum TripRole {
  OWNER
  MEMBER
}

model TripItineraryDay {
  id        String    @id @default(cuid())
  tripId    String
  dayNumber Int
  summary   String
  location  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tags      TripItineraryTag[]
  activities TripItineraryActivity[]

  @@unique([tripId, dayNumber])
  @@index([tripId, dayNumber])
}

model TripItineraryTag {
  id     String           @id @default(cuid())
  dayId  String
  label  String
  day    TripItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model TripItineraryActivity {
  id        String           @id @default(cuid())
  dayId     String
  time      String
  title     String
  type      ActivityType     @default(ACTIVITY)
  createdAt DateTime         @default(now())
  day       TripItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId, createdAt])
}

model TripBudgetItem {
  id                 String   @id @default(cuid())
  tripId             String
  title              String
  category           String
  pricingMode        BudgetPricingMode @default(GROUP_TOTAL)
  peopleCount        Int      @default(1)
  estimatedCostCents Int
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  trip               Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, createdAt])
}

enum BudgetPricingMode {
  PER_PERSON
  GROUP_TOTAL
}

enum ActivityType {
  FLIGHT
  LODGING
  FOOD
  ACTIVITY
}
